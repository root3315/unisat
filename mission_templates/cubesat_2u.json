    },
    "adcs": {
      "enabled": true,
      "tier": "magnetorquer_plus_sensors",
      "magnetorquers": 3,
      "magnetometer": "LIS3MDL",
      "imu": "MPU9250",
      "sun_sensors": 6,
      "pointing_accuracy_deg": 5.0
    },
    "gnss": {"enabled": true, "receiver": "u-blox_MAX-M10S"},
    "imu": {"enabled": true, "sensor_type": "MPU9250", "sample_rate_hz": 50},
    "camera": {"enabled": false},
    "payload": {"enabled": true, "type": "experiment"}
  },
  "features": {
    "orbit_predictor": true,
    "magnetorquers": true,
    "reaction_wheels": false,
    "eclipse_fdir": true,
    "solar_panels": true,
    "gnss": true,
    "camera": false,
    "descent_controller": false
  },
  "ground_station": {
    "antenna": {"type": "yagi", "gain_dbi": 14, "frequency_mhz": 437},
    "tnc": "direwolf", "network_port": 5001
  }
