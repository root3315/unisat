{
  "mission": {
    "name": "CubeSat 2U Mission",
    "version": "1.0.0",
    "description": "2U CubeSat: UHF + payload experiment, coarse pointing",
    "mission_type": "cubesat_2u",
    "platform": "cubesat",
    "operator": "Team Name",
    "telemetry_hz": 0.5
  },
  "satellite": {
    "form_factor": "cubesat_2u",
    "mass_kg": 2.6,
    "dimensions_mm": [100, 100, 227.0]
  },
  "orbit": {
    "type": "LEO",
    "altitude_km": 500,
    "inclination_deg": 51.6,
    "expected_lifetime_years": 2
  },
  "subsystems": {
    "obc": {"enabled": true, "mcu": "STM32F446RE", "clock_mhz": 180,
